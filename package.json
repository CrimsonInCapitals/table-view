{
	"name": "table-view",
	"displayName": "Table View",
	"description": "tables repeat new from class",
	"version": "0.0.1",
	"publisher": "CRIMSON",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/CrimsonInCapitals/table-view"
	},
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"customEditors": [

			{
				"viewType": "CRIMSON.TableView",
				"displayName": "Table View",
				"selector": [
					{"filenamePattern": "*.jsx"},
					{"filenamePattern": "*.js"},
					{"filenamePattern": "*.tv"}
				],
				"priority": "default"
			}
		],
		"commands": [
			{"command": "conditionalWebview.show",
			"title": "Open In Table View"}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -w -p ./"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/vscode": "^1.100.0",
		"eslint": "^9.13.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}